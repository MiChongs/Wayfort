bin/
# Anchor at repo root only. The bare `freerdp-worker` pattern (unanchored,
# no slash) was matching every directory tree named `freerdp-worker`,
# including the embed mirror at internal/desktop/_workersrc/cmd/freerdp-worker/,
# which silently dropped the worker source out of every commit and caused
# bootstrap to fail with "directory not found" at runtime.
/freerdp-worker
/freerdp-worker.exe
/jumpserver
/jumpserver.exe
/bin/
/var/
/configs/config.yaml
# Root-level config.yaml is the operator's private dev config (carries
# auth.jwt_secret + optional plaintext db / smtp creds). Never commit.
/config.yaml
# Phase 14 bootstrap unseal passphrase + sessions volume bind-mount.
/deployments/var/
*.log
*.cast
.DS_Store

# Editor / session-local clutter — never committed.
/.idea/
/.claude/
/.omc/
/.worktrees/
/docs/

# Web tooling — repo uses npm (package-lock.json). pnpm artifacts are
# local-only when a contributor experiments with pnpm.
/web/.omc/
/web/pnpm-lock.yaml
/web/pnpm-workspace.yaml
