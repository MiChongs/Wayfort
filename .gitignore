bin/
# Anchor at repo root only. The bare `freerdp-worker` pattern (unanchored,
# no slash) was matching every directory tree named `freerdp-worker`,
# including the embed mirror at internal/desktop/_workersrc/cmd/freerdp-worker/,
# which silently dropped the worker source out of every commit and caused
# bootstrap to fail with "directory not found" at runtime.
/freerdp-worker
/freerdp-worker.exe
/jumpserver
/jumpserver.exe
/bin/
/var/
/configs/config.yaml
# Editor / session-local artifacts that the lower section also lists; the
# top half is kept for backward-compat with older worktree-based clones.
/.worktrees/
# Root-level config.yaml is the operator's private dev config (carries
# auth.jwt_secret + optional plaintext db / smtp creds). Never commit.
/config.yaml
# Phase 14 bootstrap unseal passphrase + sessions volume bind-mount.
/deployments/var/
*.log
*.cast
.DS_Store

# Editor / session-local clutter — never committed.
/.idea/
/.claude/
/.omc/
/.worktrees/
/docs/

# Web tooling — repo uses pnpm. pnpm-lock.yaml + pnpm-workspace.yaml are
# tracked; npm's package-lock.json is not used.
/web/.omc/
/web/package-lock.json
# Per-developer dev URLs (BACKEND_HTTP_URL / NEXT_PUBLIC_BACKEND_WS_URL).
# `.env.example` covers the documentation case; `.env` is local-only.
/web/.env

# baoyu-design HTML artifacts
designs/

# License signing PRIVATE keys — must never be committed.
*license_ed25519.key
*.lic
# PRIVATE enterprise overlay — lives in a SEPARATE private repo, never in the
# open-source core. (pkg/edition holds only the public interface + Community
# default; this dir holds the real verifier/key/signer.)
/enterprise/

# Compiled binaries — never commit build artifacts.
/gateway-agent.exe
*.exe
# scripts/build-agent.sh output (prebuilt gateway-agent binaries staged for the
# /dl/gateway-agent download endpoint). Operators stage these at deploy time.
/dist/

# 产品官网(独立的 Vite + React 站点)——按要求不纳入主仓库版本控制。
/website/
