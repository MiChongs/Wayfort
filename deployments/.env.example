# Wayfort 一键部署环境变量模板。
#
# deploy.sh / deploy.ps1 首次运行时会把本文件复制为 deployments/.env 并自动填充随机密钥。
# 也可手动复制:  cp deployments/.env.example deployments/.env  然后填写下方密钥。
# ⚠️ deployments/.env 含明文密钥,已被 .gitignore 忽略,切勿提交。

# ───────────────── 对外访问 ─────────────────
# 浏览器访问的主机名/IP。本机部署填 localhost;远程部署填服务器公网 IP 或域名。
# ⚠️ 这会在「构建期」烤进前端(WebSocket 直连地址)。改动后必须重建 web 镜像
#    —— deploy 脚本的 up / update 默认带 --build,会自动重建。
PUBLIC_HOST=localhost

# Caddy 单一入口对宿主暴露的端口。浏览器访问 http://${PUBLIC_HOST}:${WEB_PORT}
# 注意:Windows 保留 ~7999–8098 段(Hyper-V/WSL 动态范围),8080/8088 常无法绑定;
# 故默认 18080。若该端口被占/被保留,换成任意空闲端口即可。
WEB_PORT=18080

# WebSocket 协议:http 部署用 ws;启用 HTTPS(域名 + Caddy 自动证书)时改为 wss。
WS_SCHEME=ws

# 页面/HTTP 协议:http;启用 HTTPS 时改为 https(与 WS_SCHEME 配套:http↔ws、https↔wss)。
# 用于 ironrdp(Devolutions Gateway)的 external_url。
PUBLIC_SCHEME=http

# 前端右下角显示的版本号(可填 git tag / 构建号)。
APP_VERSION=docker

# Devolutions Gateway(ironrdp 后端)版本。默认 2026.2.2:直接从 release CDN 下载该版本,
# 跳过易被限流/在受限沙箱里失败的 GitHub「查最新」API。改成别的版本即换版本;
# 留空才会回退到查 GitHub 最新。
DGW_VERSION=2026.2.2

# 在线 Office(仅 --office 时用到)对宿主暴露的端口。
OFFICE_PORT=18082

# ───────────────── 密钥(deploy 脚本自动生成;手动部署请自行填充强随机值)─────────────────
# JWT 签名密钥(≥32 字节)。生成示例:openssl rand -hex 32
JWT_SECRET=

# Postgres 密码(仅容器内网使用,但仍随机化)。生成示例:openssl rand -hex 24
POSTGRES_PASSWORD=

# 首个管理员(用户名 admin)的初始密码,仅首次启动建账时生效;登录后请尽快修改。
# 生成示例:openssl rand -base64 18
ADMIN_PASSWORD=

# OnlyOffice JWT 密钥(仅 --office 时用到,后端与 onlyoffice 两侧须一致)。
OFFICE_JWT_SECRET=
